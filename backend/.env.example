# Database (replace with your Coolify managed PostgreSQL URL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/sarthi?schema=public"

# JWT secret for auth tokens (generate a strong random string)
JWT_SECRET="your-jwt-secret-min-32-characters"

# Server port (Coolify usually sets PORT, default is fine)
PORT=3000

# Optional: Twilio / SMS credentials if used for OTP
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_PHONE_NUMBER=""

# MSG91 OTP integration
MSG91_AUTHKEY=""
MSG91_TEMPLATE_ID=""
MSG91_SENDER_ID=""
MSG91_OTP_LENGTH="6"
MSG91_OTP_EXPIRY="5"
